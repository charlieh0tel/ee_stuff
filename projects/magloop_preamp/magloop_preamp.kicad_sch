	)
	(text "All resitsors: thin film\n\nAll capacitors: >=25V WVDC\n\nAll electrolyic capacitors: Low ESR.\n  Panasonic FR or FC or Nichicon UWT recommended.\n\n100n capacitors: C0G/NP0, 50V"
		(exclude_from_sim no)
		(at 305.054 224.028 0)
