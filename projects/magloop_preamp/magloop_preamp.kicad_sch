	)
	(text "Q3 - MMBT3904 Emitter Follower\n\nBias divider: R8 = 10kΩ, R9 = 10kΩ\nVbase = 9V × 10k/20k = 4.5V\nVemitter = 4.5V - 0.65V = 3.85V\n\nEmitter current:\nIe = Ve / R10 = 3.85V / 470Ω = 8.2 mA\nFine for MMBT3904 (rated to 200mA).\n\nOutput impedance:\nre = 26mV / 8.2mA ≈ 3.2Ω\nRsource into Q3 base = R6 ‖ R8 ‖ R9\n= 4.7K ‖ 10K ‖ 10K ≈ 2.4KΩ\n\nZout_emitter = (re + Rsource/hFE) ‖ R10\n= (3.2 + 16) ‖ 470 ≈ 18.5Ω\nR11 = 33Ω in series after C6:\n\nZout_total ≈ 18.5 + 33 = ~52Ω\n\nVoltage gain: Av ≈ 1 (0 dB) - buffer stage only\n"
		(exclude_from_sim no)
		(at 209.55 160.02 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "acc832d4-4870-4830-afce-eeb503a19b15")
	)
