# Define the document name (without the .tex extension)
DOC = diode_smallsignal

# Define the compiler and its flags
COMPILER = pdflatex
FLAGS = -interaction=nonstopmode -halt-on-error

# The default target runs when you just type 'make'
all: $(DOC).pdf

# Rule to build the PDF from the .tex file
$(DOC).pdf: $(DOC).tex
	$(COMPILER) $(FLAGS) $(DOC).tex
	# A second run is standard practice to ensure references and table layouts resolve correctly
	$(COMPILER) $(FLAGS) $(DOC).tex

# Clean target to remove auxiliary files generated by LaTeX
clean:
	rm -f *.aux *.log *.out *.fls *.fdb_latexmk *.synctex.gz

# Deep clean target to remove auxiliary files AND the generated PDF
cleanall: clean
	rm -f $(DOC).pdf

# Tell Make that these targets aren't actual files
.PHONY: all clean cleanall
